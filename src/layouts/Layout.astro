---
import '../styles/global.css';
import { siteConfig } from '../data/config';
import NavIcon from '../components/NavIcon.astro';

interface Props {
  title?: string;
}
const { title = siteConfig.trip_name } = Astro.props;

const base = import.meta.env.BASE_URL;

// Derive footer date range from config
const depDate = new Date(siteConfig.departure_date);
const retDate = new Date(siteConfig.return_date);
const footerDates = `${depDate.getDate()}.–${retDate.getDate()}. ${retDate.getMonth() + 1}. ${retDate.getFullYear()}`;

const navLinks = [
  { href: `${base}#transport`,     label: 'Doprava', icon: 'transport' as const },
  { href: `${base}#accommodation`, label: 'Hotel',   icon: 'hotel'     as const },
  { href: `${base}#itinerary`,     label: 'Plán',    icon: 'plan'      as const },
  { href: `${base}#map`,           label: 'Mapa',    icon: 'map'       as const },
  { href: `${base}#packing`,       label: 'Balení',  icon: 'packing'   as const },
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`Cestovní itinerář — ${siteConfig.trip_name}`} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>

    <!-- Sticky navigation -->
    <nav id="nav" aria-label="Hlavní navigace">
      <div class="nav-inner container">
        <a href={`${base}#hero`} class="nav-brand" aria-label="Zpět na začátek">
          <span class="nav-brand-icon">✦</span>
          <span class="nav-brand-text">{siteConfig.trip_name}</span>
        </a>
        <ul class="nav-links" role="list">
          {navLinks.map(({ href, label, icon }) => (
            <li>
              <a href={href} class="nav-link">
                <NavIcon name={icon} />
                <span class="nav-link-text">{label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer>
      <div class="container footer-inner">
        <span class="footer-text">{siteConfig.trip_name} &mdash; {footerDates}</span>
      </div>
    </footer>

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>

  </body>
</html>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-h);
    background: rgba(250, 246, 241, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 1rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .nav-brand:hover { opacity: 1; }

  .nav-brand-icon {
    color: var(--color-terracotta);
    font-size: 0.85rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
  }

  .nav-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 0.35rem 0.75rem;
    min-height: 44px;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: var(--radius-sm);
    transition: color 0.2s, background 0.2s;
  }
  .nav-link:hover {
    color: var(--color-text);
    background: rgba(196, 149, 106, 0.1);
    opacity: 1;
  }

  :global(.nav-icon) {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: currentColor;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
  }

  .footer-inner {
    display: flex;
    justify-content: center;
  }

  .footer-text {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
    font-family: var(--font-display);
  }

  @media (max-width: 600px) {
    .nav-brand-text { display: none; }
    .nav-link {
      padding: 0.5rem;
      min-width: 44px;
      justify-content: center;
    }
    .nav-link-text { display: none; }
    :global(.nav-icon) {
      width: 22px;
      height: 22px;
    }
  }
</style>

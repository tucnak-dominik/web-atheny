---
import type { Flight } from '../lib/types';
import { formatDate, formatTime } from '../lib/utils';

interface Props {
  flight: Flight;
}
const { flight } = Astro.props;
const isReturn = flight.to.includes('PRG') || flight.to.includes('Praha');
const label = isReturn ? 'Zpáteční let' : 'Let tam';
---

<article class="card flight-card">
  <header class="flight-header">
    <span class="flight-label">{label}</span>
    <span class="flight-date">{formatDate(flight.date)}</span>
  </header>

  <div class="flight-route">
    <div class="flight-endpoint">
      <span class="flight-time">{formatTime(flight.time)}</span>
      <span class="flight-city">{flight.from}</span>
    </div>

    <div class="flight-arrow" aria-hidden="true">
      <span class="flight-number">{flight.flight_number}</span>
      <svg class="flight-line" viewBox="0 0 120 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="0" y1="12" x2="100" y2="12" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 3"/>
        <path d="M96 6 L108 12 L96 18" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <!-- Plane icon -->
        <g transform="translate(104, 5)">
          <path d="M8 4L14 7V9L8 7L6 13H4L5 7L0 5V3L5 5L7 1H9L8 4Z" fill="currentColor" transform="scale(0.7)"/>
        </g>
      </svg>
      <span class="flight-airline">{flight.airline}</span>
    </div>

    <div class="flight-endpoint flight-endpoint--right">
      <span class="flight-time flight-time--muted">&mdash;</span>
      <span class="flight-city">{flight.to}</span>
    </div>
  </div>

  {flight.notes && (
    <footer class="flight-notes">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 3a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm0 3.5c.55 0 1 .45 1 1V11a1 1 0 1 1-2 0V8.5c0-.55.45-1 1-1z"/>
      </svg>
      {flight.notes}
    </footer>
  )}
</article>

<style>
  .flight-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .flight-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .flight-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-terracotta);
  }

  .flight-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .flight-route {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.75rem;
  }

  .flight-endpoint {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .flight-endpoint--right {
    text-align: right;
    align-items: flex-end;
  }

  .flight-time {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-text);
  }
  .flight-time--muted {
    color: var(--color-text-muted);
    font-size: 1.25rem;
  }

  .flight-city {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .flight-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    color: var(--color-border);
  }

  .flight-number {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .flight-line {
    width: 80px;
    height: 16px;
    color: var(--color-terracotta);
    opacity: 0.5;
  }

  .flight-airline {
    font-size: 0.65rem;
    color: var(--color-text-muted);
  }

  .flight-notes {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: rgba(196, 149, 106, 0.07);
    border-radius: var(--radius-sm);
    padding: 0.6rem 0.75rem;
    border-left: 2px solid var(--color-terracotta);
  }

  .flight-notes svg {
    color: var(--color-terracotta);
    flex-shrink: 0;
    margin-top: 1px;
  }
</style>
